{
  "name": "handwriting-react",
  "version": "0.1.0",
  "description": "React component for handwriting animation",
  "main": "dist/handwriting-react.esm.js",
  "module": "dist/handwriting-react.esm.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/handwriting-react.esm.js --format=esm --external:react --external:react-dom",
    "build:types": "tsc --emitDeclarationOnly",
    "watch": "esbuild src/index.ts --bundle --outfile=dist/handwriting-react.esm.js --format=esm --external:react --external:react-dom --watch"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "esbuild": "^0.20.0",
    "handwriting-playback": "file:../playback",
    "typescript": "^5.3.0"
  }
}
