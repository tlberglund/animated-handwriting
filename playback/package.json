{
  "name": "handwriting-playback",
  "version": "0.1.0",
  "description": "Handwriting animation playback engine",
  "main": "src/index.ts",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/handwriting-animator.js --format=iife --global-name=HandwritingAnimatorLib",
    "build:esm": "esbuild src/index.ts --bundle --outfile=dist/handwriting-animator.esm.js --format=esm",
    "watch": "esbuild src/index.ts --bundle --outfile=dist/handwriting-animator.js --format=iife --global-name=HandwritingAnimatorLib --watch"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
